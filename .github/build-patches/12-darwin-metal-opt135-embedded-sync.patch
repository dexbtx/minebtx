+    thread uchar seed_a[32];
+    thread uchar seed_b[32];
+    thread uchar header_hash[32];
+    thread uchar sigma[32];
+
+    if (p.seed_version == 3u) {
+        thread uchar msg[160];
+        const uint slen = build_seed_v3_message(msg, previous_block_hash, merkle_root,
+                                                p.parent_median_time_past, p.height, p.version,
+                                                p.time, p.bits, nonce, (ushort)p.matmul_dim, 0u);
+        thread uint st[8];
+        for (uint i = 0; i < 8; ++i) { st[i] = sh_seed_mid[i]; }
