+        compute_matmul_seed_v2(previous_block_hash, merkle_root, p.height, p.version, p.time, p.bits,
+                               nonce, (ushort)p.matmul_dim, 0u, seed_a);
+        compute_matmul_seed_v2(previous_block_hash, merkle_root, p.height, p.version, p.time, p.bits,
+                               nonce, (ushort)p.matmul_dim, 1u, seed_b);
+    }
+
+    thread uchar hmsg[160];
+    const uint hlen = build_header_message(hmsg, p.version, previous_block_hash, merkle_root, p.time,
+                                           p.bits, nonce, (ushort)p.matmul_dim, seed_a, seed_b);
+    thread uint hst[8];
+    for (uint i = 0; i < 8; ++i) { hst[i] = sh_hdr_mid[i]; }
+    sha256_bytes_from_block(hmsg, hlen, 1u, hst, header_hash);
