+    uint offset = 0u;
+    append_le32(message, offset, version);
+    append_constant_bytes(message, offset, previous_block_hash, 32u);
+    append_constant_bytes(message, offset, merkle_root, 32u);
+    append_le32(message, offset, time);
+    append_le32(message, offset, bits);
+    append_le64(message, offset, nonce);
+    append_le16(message, offset, matmul_dim);
+    append_thread_bytes(message, offset, seed_a, 32u);
+    append_thread_bytes(message, offset, seed_b, 32u);
+    return offset; // 150
+}
+
+kernel void scan_nonce_seed_pre_hash_mid(constant NonceSeedScanParams& p [[buffer(0)]],
+                                         constant uchar* previous_block_hash [[buffer(1)]],
+                                         constant uchar* merkle_root [[buffer(2)]],
+                                         constant uchar* pre_hash_target [[buffer(3)]],
+                                         device uint* out_flags [[buffer(4)]],
+                                         uint gid [[thread_position_in_grid]],
+                                         uint tid [[thread_index_in_threadgroup]])
+{
+    threadgroup uint sh_seed_mid[8];   // SHA state after seed-v3 block 0 (v3 only)
+    threadgroup uint sh_hdr_mid[8];    // SHA state after header-hash block 0
+    if (tid == 0u) {
+        thread uchar msg[160];
+        if (p.seed_version == 3u) {
+            build_seed_v3_message(msg, previous_block_hash, merkle_root, p.parent_median_time_past,
+                                  p.height, p.version, p.time, p.bits, 0ul, (ushort)p.matmul_dim, 0u);
+            thread uint st[8];
+            sha256_midstate0(msg, st);
+            for (uint i = 0; i < 8; ++i) { sh_seed_mid[i] = st[i]; }
+        }
+        thread uchar zero[32];
+        for (uint i = 0; i < 32; ++i) { zero[i] = 0u; }
+        build_header_message(msg, p.version, previous_block_hash, merkle_root, p.time, p.bits,
+                             0ul, (ushort)p.matmul_dim, zero, zero);
+        thread uint hst[8];
+        sha256_midstate0(msg, hst);
+        for (uint i = 0; i < 8; ++i) { sh_hdr_mid[i] = hst[i]; }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    if (gid >= p.scan_count) {
+        return;
+    }
+    const ulong nonce = p.start_nonce + (ulong)gid;
+    thread uchar seed_a[32];
+    thread uchar seed_b[32];
+    thread uchar header_hash[32];
+    thread uchar sigma[32];
+
+    if (p.seed_version == 3u) {
+        thread uchar msg[160];
+        const uint slen = build_seed_v3_message(msg, previous_block_hash, merkle_root,
+                                                p.parent_median_time_past, p.height, p.version,
+                                                p.time, p.bits, nonce, (ushort)p.matmul_dim, 0u);
+        thread uint st[8];
+        for (uint i = 0; i < 8; ++i) { st[i] = sh_seed_mid[i]; }
+        sha256_bytes_from_block(msg, slen, 1u, st, seed_a);
+        msg[117] = 1u;  // `which` byte (offset 117, in block 1); flip 0->1 for seed_b, reuse midstate
+        for (uint i = 0; i < 8; ++i) { st[i] = sh_seed_mid[i]; }
+        sha256_bytes_from_block(msg, slen, 1u, st, seed_b);
+    } else {
+        compute_matmul_seed_v2(previous_block_hash, merkle_root, p.height, p.version, p.time, p.bits,
+                               nonce, (ushort)p.matmul_dim, 0u, seed_a);
+        compute_matmul_seed_v2(previous_block_hash, merkle_root, p.height, p.version, p.time, p.bits,
+                               nonce, (ushort)p.matmul_dim, 1u, seed_b);
+    }
+
+    thread uchar hmsg[160];
+    const uint hlen = build_header_message(hmsg, p.version, previous_block_hash, merkle_root, p.time,
+                                           p.bits, nonce, (ushort)p.matmul_dim, seed_a, seed_b);
+    thread uint hst[8];
+    for (uint i = 0; i < 8; ++i) { hst[i] = sh_hdr_mid[i]; }
+    sha256_bytes_from_block(hmsg, hlen, 1u, hst, header_hash);
+    sha256_bytes(header_hash, 32u, sigma);
+    out_flags[gid] = uint256_internal_bytes_less_or_equal(sigma, pre_hash_target) ? 1u : 0u;
+}
